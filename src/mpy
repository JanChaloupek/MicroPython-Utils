#!/usr/bin/env python3
import sys
import os
from tools import utils

COMMANDS = {
    "test": "test_signal",
    "upload": "upload",
    "main": "upload_main",
    "runmain": "run_main",
    "list": "list",
    "check": "check",
    "repl": "repl",
    "wipe": "wipe",
    "setup": "setup_project",
    "help": None,
    "version": None,
}

def show_help():
    utils.info("Dostupne prikazy:")
    print("  upload    - nahrani celeho projektu")
    print("  main      - nahrani pouze main.py")
    print("  runmain   - spusteni main.py bez nahravani")
    print("  list      - vypis obsahu zarizeni")
    print("  check     - diagnostika zarizeni")
    print("  repl      - REPL konzole (TODO)")
    print("  wipe      - smazani obsahu zarizeni")
    print("  setup     - kompletni priprava projektu")
    print("  help      - tato napoveda")
    print("  version   - verze nastroje")

def main():
    utils.banner("mpy CLI", version="0.1.0")

    if len(sys.argv) < 2:
        show_help()
        return 0

    cmd = sys.argv[1].lower()

    if cmd == "help":
        show_help()
        return 0

    if cmd == "version":
        print("mpy CLI version 0.1.0")
        return 0

    if cmd not in COMMANDS:
        utils.error(f"Neznamy prikaz: {cmd}")
        show_help()
        return 1

    module_name = COMMANDS[cmd]
    if module_name is None:
        utils.error(f"Prikaz '{cmd}' zatim neni implementovan.")
        return 1

    # zavolame prislusny modul v tools/
    try:
        mod = __import__(f"tools.{module_name}", fromlist=["run"])
    except ImportError as e:
        utils.error(f"Nelze nacist modul pro prikaz '{cmd}': {e}")
        return 1

    if not hasattr(mod, "run"):
        utils.error(f"Modul tools.{module_name} nema funkci run().")
        return 1

    # predame zbytek argumentu
    return mod.run(sys.argv[2:])

if __name__ == "__main__":
    sys.exit(main())
